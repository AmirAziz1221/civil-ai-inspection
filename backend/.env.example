# ─── LLM Configuration ────────────────────────────────────────────────────────
# Replace these values to switch LLM providers (OpenAI, Ollama, Groq, etc.)

# OpenAI (default)
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o-mini

# --- Ollama (local, free) ---
# LLM_API_BASE=http://ollama:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# --- Groq (fast, free tier) ---
# LLM_API_BASE=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your-groq-key
# LLM_MODEL=llama3-70b-8192

# --- Anthropic Claude via OpenAI-compatible proxy ---
# LLM_API_BASE=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-your-key
# LLM_MODEL=claude-3-haiku-20240307

LLM_TIMEOUT=60

# ─── Paths ────────────────────────────────────────────────────────────────────
MODELS_DIR=models
DB_PATH=inspections.db

# ─── App ──────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
